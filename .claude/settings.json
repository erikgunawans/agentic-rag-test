{
  "permissions": {
    "allow": [
      "WebFetch(domain:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(docker:*)",
      "Bash(rm -rf:*)",
      "Read(./.env)",
      "Read(~/.ssh/**)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$TOOL_INPUT_file_path\"; case \"$file\" in */frontend/*.ts|*/frontend/*.tsx) cd frontend && npx eslint --fix \"$file\" 2>/dev/null; npx tsc --noEmit 2>&1 | head -5;; */backend/*.py) cd backend && python3 -m py_compile \"$file\" 2>&1;; esac",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT_file_path\" | grep -qE '\\.(env|env\\..*)$' && echo 'BLOCKED: Cannot edit env files' && exit 1 || exit 0"
          }
        ]
      }
    ]
  }
}
