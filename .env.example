# Copy this file to .env and fill in your values

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI (used for embeddings) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Leave empty — no longer used from Module 2 onward
OPENAI_VECTOR_STORE_ID=

# ── OpenRouter (used for chat completions — Module 2+) ────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── RAG tuning ────────────────────────────────────────────────────────────────
# Similarity threshold: 0.3 works well for text-embedding-3-small
RAG_SIMILARITY_THRESHOLD=0.3
RAG_TOP_K=5

# ── LangSmith (optional) ──────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=rag-masterclass
LANGCHAIN_TRACING_V2=false

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_BASE_URL=http://localhost:8000
